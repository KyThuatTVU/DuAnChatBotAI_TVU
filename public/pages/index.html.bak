<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CELRAS TVU Chatbot - Trung tâm Học liệu và Chuyển đổi số</title>

    <!-- Tailwind CDN: viết class trực tiếp vào HTML, có hiệu lực ngay, không cần build -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'ui-sans-serif', 'system-ui'] } } }
        }
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" href="/DuAnChatbotThuVien/public/assets/images/logo.png" type="image/png">

    <style>
        /* ===== Style cho các phần tử do JS inject động ===== */
        body { font-family: 'Inter', ui-sans-serif, system-ui, sans-serif; }

        /* Tin nhắn */
        .message { display: flex; align-items: flex-start; gap: 10px; margin-bottom: 16px; }
        .message.user { flex-direction: row-reverse; }
        .message .avatar { width: 32px; height: 32px; border-radius: 50%; flex-shrink: 0; }
        .message.bot .bubble {
            background: #ffffff; color: #1f2937;
            border-radius: 0 16px 16px 16px;
            padding: 10px 14px; max-width: 72%;
            font-size: 14px; line-height: 1.6;
            box-shadow: 0 1px 4px rgba(0,0,0,0.08);
            border: 1px solid #e5e7eb;
        }
        .message.user .bubble {
            background: #0ea5e9; color: #fff;
            border-radius: 16px 0 16px 16px;
            padding: 10px 14px; max-width: 72%;
            font-size: 14px; line-height: 1.6;
        }

        /* Typing indicator */
        .typing-indicator { display: flex; gap: 4px; align-items: center; padding: 4px 0; }
        .typing-indicator span {
            display: inline-block; width: 7px; height: 7px;
            border-radius: 50%; background: #93c5fd;
            animation: tw-bounce 1.2s infinite;
        }
        .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
        .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes tw-bounce {
            0%, 80%, 100% { transform: translateY(0); }
            40%           { transform: translateY(-6px); }
        }

        /* Suggestion chip do JS render */
        .suggestion-chip {
            display: inline-flex; align-items: center;
            padding: 8px 16px;
            border: 1px solid #bae6fd; border-radius: 9999px;
            background: rgba(255,255,255,0.75);
            color: #0369a1; font-size: 13px; font-weight: 500;
            cursor: pointer; transition: all 0.15s;
            backdrop-filter: blur(4px);
        }
        .suggestion-chip:hover { background: #e0f2fe; border-color: #7dd3fc; }

        /* ===== SIDEBAR DANH MỤC ===== */
        #categorySidebar {
            width: 280px; flex-shrink: 0;
            background: rgba(255,255,255,0.92);
            border-right: 1px solid #e0f2fe;
            backdrop-filter: blur(8px);
            display: flex; flex-direction: column;
            overflow: hidden;
            transition: margin-left 0.3s ease;
        }
        #categorySidebar.sidebar-hidden {
            margin-left: -280px;
        }
        #categorySidebar .sidebar-header {
            padding: 16px 18px 12px;
            border-bottom: 1px solid #e5e7eb;
            flex-shrink: 0;
        }
        #categorySidebar .sidebar-body {
            flex: 1; overflow-y: auto; padding: 8px 0;
        }
        #categorySidebar .sidebar-body::-webkit-scrollbar { width: 4px; }
        #categorySidebar .sidebar-body::-webkit-scrollbar-track { background: transparent; }
        #categorySidebar .sidebar-body::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 9999px; }

        /* Category item dạng dòng trong sidebar */
        .category-item {
            display: flex; align-items: center; gap: 10px;
            padding: 10px 18px;
            cursor: pointer; transition: all 0.15s ease;
            border-left: 3px solid transparent;
        }
        .category-item:hover {
            background: #f0f9ff;
            border-left-color: #7dd3fc;
        }
        .category-item.active {
            background: #e0f2fe;
            border-left-color: #0ea5e9;
        }
        .category-item .cat-icon {
            font-size: 20px; flex-shrink: 0; width: 32px; text-align: center;
        }
        .category-item .cat-info {
            flex: 1; min-width: 0;
        }
        .category-item .cat-name {
            font-size: 13px; font-weight: 600; color: #1e3a5f;
            line-height: 1.3; white-space: nowrap;
            overflow: hidden; text-overflow: ellipsis;
        }
        .category-item.active .cat-name { color: #0369a1; }
        .category-item .cat-count {
            font-size: 11px; color: #94a3b8; margin-top: 1px;
        }
        .category-item .cat-arrow {
            flex-shrink: 0; color: #cbd5e1; transition: all 0.15s;
        }
        .category-item:hover .cat-arrow { color: #0ea5e9; }
        .category-item.active .cat-arrow { color: #0ea5e9; transform: rotate(90deg); }

        /* Sub-questions bên dưới category item */
        .category-questions {
            display: none;
            background: #f8fafc;
        }
        .category-questions.open {
            display: block;
        }
        .cat-question-item {
            display: flex; align-items: center; gap: 8px;
            padding: 9px 18px 9px 48px;
            cursor: pointer; transition: background 0.15s;
            font-size: 13px; color: #475569; line-height: 1.4;
        }
        .cat-question-item:hover {
            background: #e0f2fe;
            color: #0369a1;
        }
        .cat-question-item .q-dot {
            flex-shrink: 0; width: 5px; height: 5px;
            border-radius: 50%; background: #93c5fd;
        }
        .cat-question-item .q-text {
            flex: 1;
        }

        /* Toggle button cho mobile */
        #sidebarToggle {
            display: none;
        }
        @media (max-width: 768px) {
            #categorySidebar {
                position: fixed; top: 64px; left: 0; bottom: 0;
                z-index: 40; width: 280px;
                box-shadow: 4px 0 24px rgba(0,0,0,0.12);
                background: rgba(255,255,255,0.98);
                margin-left: 0; /* reset margin on mobile */
                transform: translateX(0);
                transition: transform 0.3s ease;
            }
            #categorySidebar.sidebar-hidden {
                margin-left: 0;
                transform: translateX(-100%);
            }
            #sidebarToggle {
                display: inline-flex;
            }
            #sidebarOverlay {
                display: none; position: fixed; inset: 0; top: 64px;
                background: rgba(0,0,0,0.3); z-index: 39;
                pointer-events: none;
            }
            #sidebarOverlay.active {
                display: block;
                pointer-events: auto;
            }

            /* Main layout - bỏ justify-center để nội dung không bị cắt */
            main.flex-1 {
                justify-content: flex-start !important;
            }

            /* Header */
            header .max-w-7xl {
                padding-left: 12px !important;
                padding-right: 12px !important;
            }

            /* Welcome block */
            #welcomeBlock {
                padding-top: 1.5rem !important;
                padding-bottom: 0.5rem !important;
            }
            #welcomeBlock img {
                width: 64px !important; height: 64px !important;
                margin-bottom: 12px !important;
            }
            #welcomeBlock h2 {
                font-size: 1.1rem !important;
                margin-bottom: 8px !important;
            }
            #welcomeBlock p {
                font-size: 12.5px !important;
                padding-left: 8px !important;
                padding-right: 8px !important;
            }
            #welcomeBlock p br {
                display: none;
            }

            /* Chat area */
            main {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
            #chatMessages {
                padding-left: 8px !important;
                padding-right: 8px !important;
                padding-top: 8px !important;
            }

            /* Message bubbles */
            .message .bubble {
                max-width: 88% !important;
                font-size: 13px !important;
            }
            .message .avatar {
                width: 28px !important; height: 28px !important;
            }

            /* Suggestions */
            #suggestionsContainer {
                padding: 0 4px !important;
            }
            #suggestionsContainer > div {
                flex-wrap: wrap !important;
                gap: 6px !important;
                justify-content: center !important;
            }
            .suggestion-chip {
                font-size: 11.5px !important;
                padding: 5px 10px !important;
            }

            /* Input area */
            .flex-shrink-0 {
                padding-left: 8px !important;
                padding-right: 8px !important;
                padding-bottom: 8px !important;
                padding-top: 6px !important;
            }
            .max-w-4xl.mx-auto.mb-5 {
                margin-bottom: 10px !important;
            }
            #chatInput {
                font-size: 14px !important;
            }

            /* Footer - thu gọn trên mobile */
            footer {
                padding: 8px 12px !important;
            }
            footer p {
                font-size: 10px !important;
            }
            footer .space-y-3 > * + * {
                margin-top: 2px !important;
            }
        }

        /* Extra small screens (< 400px) */
        @media (max-width: 400px) {
            header {
                height: 56px !important;
            }
            #categorySidebar {
                top: 56px !important;
                width: 260px !important;
            }
            #sidebarOverlay {
                top: 56px !important;
            }
            .flex.flex-1.overflow-hidden {
                margin-top: 56px !important;
            }
            #welcomeBlock {
                padding-top: 1rem !important;
            }
            #welcomeBlock img {
                width: 56px !important; height: 56px !important;
            }
            #welcomeBlock h2 {
                font-size: 1rem !important;
            }
            #welcomeBlock p {
                font-size: 11.5px !important;
            }
            .suggestion-chip {
                font-size: 11px !important;
                padding: 4px 8px !important;
            }
            footer {
                padding: 6px 10px !important;
            }
            footer p {
                font-size: 9px !important;
            }
        }

        /* Scrollbar mỏng */
        #chatMessages::-webkit-scrollbar { width: 4px; }
        #chatMessages::-webkit-scrollbar-track { background: transparent; }
        #chatMessages::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 9999px; }

        /*Hiệu ứng vẫy tay*/
        @keyframes wave {
            0% { transform: rotate(0deg); }
            10% { transform: rotate(15deg); }
            20% { transform: rotate(-10deg); }
            30% { transform: rotate(15deg); }
            40% { transform: rotate(-5deg); }
            50% { transform: rotate(10deg); }
            60% { transform: rotate(0deg); }
            100% { transform: rotate(0deg); }
        }

        .wave {
            display: inline-block;
            transform-origin: 70% 70%;
            animation: wave 2s ease-in-out infinite;
        }
    </style>
</head>

<body class="bg-gradient-to-br from-sky-100 via-blue-50 to-cyan-100 h-screen flex flex-col overflow-hidden">

    <!-- ===== HEADER ===== -->
    <header class="bg-white shadow-sm fixed top-0 left-0 right-0 z-50 h-16" style="flex-shrink:0;">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 h-full flex items-center justify-between">

            <!-- Trái: Logo + Tên thương hiệu + Nút tạo chat mới -->
            <div class="flex items-center gap-3">
                <a href="/DuAnChatbotThuVien/public/pages/index.html" class="flex items-center gap-2">
                    <img
                        src="../assets/images/logo2.png"
                        alt="CELRAS TVU"
                        class="w-9 h-9 rounded-full object-cover">
                    <span class="font-bold text-blue-700 text-base hidden sm:inline">CELRAS TVU Chatbot</span>
                </a>
                <span class="text-gray-300 hidden sm:inline text-lg">|</span>
                <button
                    id="sidebarToggle"
                    onclick="toggleSidebar()"
                    class="items-center gap-1.5 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-3 py-2 rounded-full transition-colors"
                    title="Danh mục câu hỏi"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                </button>
                <button
                    onclick="startNewChat()"
                    class="inline-flex items-center gap-1.5 bg-blue-500 hover:bg-blue-600 active:bg-blue-700 text-white text-sm font-semibold px-4 py-2 rounded-full transition-colors shadow-sm"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                        <title xmlns="">square-pen</title><g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/></g>
                    </svg>
                    <span class="hidden sm:inline">Đoạn chat mới</span>
                </button>
            </div>

            <!-- Phải: Link trang chủ -->
            <div class="flex items-center gap-3">
                <a href="#" class="text-gray-500 hover:text-gray-800 text-sm font-medium hidden sm:inline transition-colors">
                    Trở về trang chủ
                </a>
            </div>

        </div>
    </header>


    <!-- ===== LAYOUT: SIDEBAR + CHAT ===== -->
    <div class="flex flex-1 overflow-hidden" style="margin-top: 64px;">

    <!-- Overlay cho mobile -->
    <div id="sidebarOverlay" onclick="toggleSidebar()" style="display:none;"></div>

    <!-- ===== SIDEBAR DANH MỤC (BÊN TRÁI) ===== -->
    <aside id="categorySidebar" class="sidebar-hidden">
        <div class="sidebar-header">
            <h3 class="text-sm font-bold text-blue-800 uppercase tracking-wider flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
                </svg>
                Danh mục câu hỏi
            </h3>
            <p class="text-xs text-gray-400 mt-1">Chọn danh mục để xem nhanh</p>
        </div>
        <div class="sidebar-body">
            <div id="categoryList">
                <!-- JS sẽ render danh mục vào đây -->
            </div>
        </div>
    </aside>

    <!-- ===== KHU VỰC CHAT CHÍNH ===== -->
    <main class="flex-1 flex flex-col justify-center overflow-hidden px-4">

        <!-- Vùng cuộn tin nhắn -->
        <div id="chatMessages" class="flex-1 overflow-y-auto px-4 py-6 pb-2">
            <div class="max-w-3xl mx-auto">

                <!-- Khối chào mừng -->
                <div id="welcomeBlock" class="flex flex-col items-center text-center pt-12 sm:pt-16 pb-6">
                    <img
                        id="botAvatarImg"
                        src="../assets/images/logo1.png"
                        alt="CELRAS Bot"
                        class="w-24 h-24 rounded-full object-cover shadow-xl mb-5 border-4 border-white"
                    >
                    <h2 class="text-blue-600 font-bold text-xl sm:text-2xl mb-3">
                        CELRAS TVU xin chào! 
                        <span class="wave">👋</span>
                    </h2>
                    <p class="text-gray-700 text-sm sm:text-base leading-relaxed max-w-2xl mx-auto text-center px-6">
                        Bạn đang kết nối với 
                        <strong class="text-gray-900 font-semibold">CELRAS TVU Chatbot</strong> – trợ lý ảo của Trung tâm Học liệu 
                        <br> và Hỗ trợ Học thuật, Đại học Trà Vinh. Nếu có thắc mắc về thư viện, tài liệu 
                        <br> hoặc dịch vụ số,... đừng ngần ngại đặt câu hỏi để được hỗ trợ ngay nhé!
                    </p>
                </div>

                <!-- Các tin nhắn sẽ được JS thêm vào đây -->

            </div>
        </div>

        <!-- ===== INPUT + CÂU HỎI GỢI Ý (ghim phía dưới) ===== -->
        <div class="flex-shrink-0 px-4 pb-6 pt-3 bg-gradient-to-t from-sky-100/95 to-transparent">

            <!-- Câu hỏi gợi ý -->
            <div class="max-w-4xl mx-auto mb-5">
                <div id="suggestionsContainer" class="max-w-4xl mx-auto space-y-3">

                    <div class="flex justify-center gap-4">
                        <button class="suggestion-chip" onclick="sendSuggestion(this)">Thư viện mở cửa lúc mấy giờ?</button>
                        <button class="suggestion-chip" onclick="sendSuggestion(this)">Làm thế nào để mượn sách?</button>
                        <button class="suggestion-chip" onclick="sendSuggestion(this)">Làm thẻ thư viện ở đâu?</button>
                    </div>
                    <div class="flex justify-center gap-4">
                        <button class="suggestion-chip" onclick="sendSuggestion(this)">Tra cứu sách như thế nào?</button>
                        <button class="suggestion-chip" onclick="sendSuggestion(this)">Thời hạn mượn sách là bao lâu?</button>
                    </div>

                </div>
            </div>

            <!-- Ô nhập tin nhắn -->
            <div class="max-w-3xl mx-auto">
                <div class="bg-white rounded-2xl shadow-md border border-gray-200 flex items-end gap-2 px-4 py-3">
                    <textarea
                        id="chatInput"
                        placeholder="Nhắn tin cho CELRAS TVU Chatbot..."
                        rows="1"
                        maxlength="3000"
                        onkeydown="handleKeyDown(event)"
                        oninput="updateCharCount(); autoResize(this)"
                        class="flex-1 text-sm text-gray-700 placeholder-gray-400 bg-transparent border-none outline-none resize-none leading-relaxed"
                        style="max-height: 100px; overflow-y: auto;"
                    ></textarea>

                    <div class="flex flex-col items-end gap-1 flex-shrink-0">
                        <span id="charCount" class="text-xs text-gray-400 tabular-nums">0 / 3000</span>

                        <button
                            id="sendBtn"
                            onclick="sendMessage()"
                            disabled
                            class="w-9 h-9 flex items-center justify-center rounded-full bg-blue-500 hover:bg-blue-600 disabled:bg-gray-200 disabled:cursor-not-allowed transition-colors text-white shadow-sm"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5"/>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

        </div>
    </main>

    </div><!-- end flex sidebar+chat -->

    <!-- ===== FOOTER ===== -->
    <footer class="bg-blue-900 text-white py-4 px-6">
        <div class="max-w-5xl mx-auto text-center space-y-3">
            

            <p class="font-semibold uppercase tracking-wide text-blue-200">
                TRUNG TÂM HỌC LIỆU VÀ HỖ TRỢ HỌC THUẬT, ĐẠI HỌC TRÀ VINH.
            </p>


            <p class="text-blue-100">
                Tel. (02943) 855 246 - 102. Email: celras@tvu.edu.vn
            </p>
        </div>
    </footer>


    <!-- ===== SCRIPTS ===== -->
    <script src="/DuAnChatbotThuVien/public/assets/js/chatbot.js?v=7"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initChatbot();
        });
    </script>
</body>
</html>
