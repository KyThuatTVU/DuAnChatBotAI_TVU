# ===================================================
# CELRAS TVU Chatbot - Environment Example
# Sao chép file này, đổi tên thành .env và điền giá trị thật
# ===================================================

# -------- Database --------
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=chatbot_thuvien

# -------- URL --------
BASE_URL=http://localhost/DuAnChatbotThuVien/public
FRONTEND_URL=http://localhost/DuAnChatbotThuVien/public/pages

# -------- Google OAuth 2.0 --------
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# -------- Upload --------
MAX_FILE_SIZE_MB=10

# -------- App --------
APP_NAME=CELRAS TVU Chatbot
APP_ENV=local
APP_DEBUG=true
